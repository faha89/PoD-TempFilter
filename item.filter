ItemDisplay[GOLD<100 CLVL<20]:
ItemDisplay[GOLD<2000 (CLVL>19 AND CLVL<=69)]:
ItemDisplay[GOLD<7000 CLVL>69]:
//ItemDisplay[GOLD>0]: %NAME%

ItemDisplay[key]: //Hide keys. You can still buy them.
ItemDisplay[gcv OR gcw OR gcg OR gcr OR gcb OR gcy OR skc]: //Ignore Chipped Gems
ItemDisplay[gfv OR gfw OR gfg OR gfr OR gfb OR gfy OR skf]: //Ignore Flawed Gems
ItemDisplay[gsv OR gsw OR gsg OR gsr OR gsb OR gsy OR sku]: //Ignore Regular Gems
//ItemDisplay[glg OR glb OR gly OR glr]: //Ignore All Flawless Except for Amethyst, Diamond, and Skull

ItemDisplay[gzv]: %NL%         %ORANGE%[%PURPLE%Amethyst%ORANGE%]         %NL% //Flawless Amethyst
ItemDisplay[glw]: %NL%         %ORANGE%[%WHITE%Diamond%ORANGE%]         %NL% //Flawless Diamond
ItemDisplay[glg]: %NL%         %ORANGE%[%GREEN%Emerald%ORANGE%]         %NL% //Flawless Emerald
ItemDisplay[glr]: %NL%         %ORANGE%[%RED%Ruby%ORANGE%]         %NL% //Flawless Ruby
ItemDisplay[glb]: %NL%         %ORANGE%[%BLUE%Sapphire%ORANGE%]         %NL% //Flawless Sapphire
ItemDisplay[gly]: %NL%         %ORANGE%[%YELLOW%Topaz%ORANGE%]         %NL% //Flawless Topaz
ItemDisplay[skl]: %NL%         %ORANGE%[%GRAY%Skull%ORANGE%]         %NL% //Flawless Skull

ItemDisplay[gpv]: %PURPLE%Perfect Amethyst //Perfect Gems
ItemDisplay[gpw]: %WHITE%Perfect Diamond
ItemDisplay[gpg]: %GREEN%Perfect Emereld
ItemDisplay[gpr]: %RED%Perfect Ruby
ItemDisplay[gpb]: %BLUE%Perfect Sapphire
ItemDisplay[gpy]: %YELLOW%Perfect Topaz
ItemDisplay[skz]: %GRAY%Perfect Skull

ItemDisplay[INF]: //Ignore Inferior Equipment

ItemDisplay[yps CLVL>41]: //Ignore all Antidote Potions
ItemDisplay[wms CLVL>41]: //Ignore all Thawing Potions
ItemDisplay[vps CLVL>41]: //Ignore all Stamina Potions
ItemDisplay[gpm OR opm OR opl OR ops OR gps OR gpl]: //Hide Choking, Exploding, Fulminating, Oil, Rancid, Strangling Potions
ItemDisplay[MAG !ID (aq2 OR cq2) CLVL>69]: //Ignore Unidentified Magic Arrows/Bolts (Level 70+)

ItemDisplay[RUNE<10]: %TAN%%RUNENAME% Rune %GRAY%(%RUNENUM%)
ItemDisplay[RUNE<20]: %NL%%TAN%%RUNENAME% Rune %GRAY%(%RUNENUM%)%NL%%NOTIFY-ITEM%
ItemDisplay[(RUNE>19 AND RUNE<26)]: %NL%%NL%         %PURPLE%###  %WHITE%%RUNENAME% RUNE %GRAY%(%RUNENUM%)  %PURPLE%###         %NL%%NL%%NOTIFY-ITEM%
ItemDisplay[RUNE>25]: %NL%%NL%         %PURPLE%@@@@@@@@@  %TAN%%RUNENAME% RUNE %GRAY%(%RUNENUM%)  %PURPLE%@@@@@@@@@         %NL%%NL%%NOTIFY-ITEM%


//║                     ▬▬▬▬▬ Town Portal and ID Scrolls/Tomes and Keys ▬▬▬▬▬                     ║
