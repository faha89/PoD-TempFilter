//║█║                             Equipment and Magic Item Handling                             ║█║
ItemDisplay[RW !ETH]: %WHITE%%NAME%%CONTINUE%//%RED%[%WHITE%%SOCKETS%%RED%]
ItemDisplay[RW ETH]: %GRAY%Eth %NAME%//%RED%[%WHITE%%SOCKETS%%RED%]
//─────────────────────────────────────────────────────────────────────────────────────────────────
//║                   ▬▬▬▬▬ [Optional] Rules for Ignoring Specific Items ▬▬▬▬▬                    ║
//ItemDisplay[MAG !ID cm2]: //Ignore unidentified magic large charms.
//ItemDisplay[MAG !ID rin CLVL>69]: //Ignore unidentified magic rings at level 70+.
//ItemDisplay[MAG !ID jew ILVL<66]: //Ignore unidentified magic jewels unless they have an item level high enough for ED +40%.

ItemDisplay[MAG !ID (cm1 OR cm2 OR cm3 OR jew)]: %NL%%DOT-9B%%GREEN%####   %BLUE%%NAME% %WHITE%[%GRAY%%ILVL%%WHITE%]   %GREEN%####%NL% //Magical Unid SC/GC
ItemDisplay[MAG !ID cm2]: %BLUE%%NAME% %WHITE%[%GRAY%Lv.%ILVL%%WHITE%]  //Magical Unid Large Charm
ItemDisplay[RARE !ID (jew OR rin OR amu)]: %NL%%NL%%DOT-9B%%GREEN%#### %YELLOW%%NAME%%WHITE%[%GRAY%L%ILVL%%WHITE%] %GREEN%####%NL%%NL% //Unidentified Rare Jewel, Ring, Ammy
ItemDisplay[RARE !ID (ci0 OR ci1 OR ci2 OR ci3)]: %NL%%NL%%DOT-9B%%GREEN%#### %YELLOW%%NAME%%WHITE%[%GRAY%%ILVL%%WHITE%] %GREEN%####%NL%%NL% //Rare Circlets

ItemDisplay[RARE (jew OR rin OR amu)]: %YELLOW%%NAME% %WHITE%[%GRAY%%ILVL%%WHITE%] //Identified Rare Jewel, Ring, Ammy
ItemDisplay[MAG (jew OR rin OR amu)]: %BLUE%%NAME% %WHITE%[%GRAY%%ILVL%%WHITE%] //Identified Rare Jewel, Ring, Ammy
ItemDisplay[MAG ID (cm1 OR cm2 OR cm3 OR jew)]: %BLUE%%NAME% %WHITE%[%GRAY%%ILVL%%WHITE%] //Magical SC/GC

//╔═══════════════════════════════════════════════════════════════════════════════════════════════╗
//║                           ▬▬▬▬▬ General Equipment Processing ▬▬▬▬▬                            ║
//╚═══════════════════════════════════════════════════════════════════════════════════════════════╝
// Use the rule below to change the color of the base name of ethereal non-magical items. Default
// color for this rule if used is to set it to %RED%.
//ItemDisplay[NMAG ETH]: %RED%ETH %ORANGE%%NAME%%CONTINUE%

ItemDisplay[ETH UNI]: %NL%         %GRAY%ETH %GOLD%%NAME%%NOTIFY-ITEM%         %NL%%CONTINUE%
ItemDisplay[ETH SET]: %NL%         %GRAY%ETH %GREEN%%NAME%%NOTIFY-ITEM%         %NL%%CONTINUE%
ItemDisplay[ETH MAG]: %RED%ETH %BLUE%%NAME%%CONTINUE%
ItemDisplay[ETH NMAG]: %RED%ETH %GRAY%%NAME%%CONTINUE%
ItemDisplay[ETH RARE]: %RED%ETH %YELLOW%%NAME%%CONTINUE%

ItemDisplay[NMAG !ETH]: %WHITE%%NAME%%CONTINUE%
ItemDisplay[MAG]: %BLUE%%NAME%%CONTINUE%
ItemDisplay[RARE]: %YELLOW%%NAME%%CONTINUE%
ItemDisplay[SET !ID]: %NL%         %GREEN%%NAME%%NOTIFY-ITEM%         %NL%%CONTINUE%
ItemDisplay[UNI !ID]: %NL%         %GOLD%%NAME%%NOTIFY-ITEM%         %NL%%CONTINUE%
ItemDisplay[!(NMAG OR MAG OR RARE OR SET OR UNI)]: %ORANGE%%NAME%%CONTINUE%


// ----- Specific Items -----
ItemDisplay[!SUP uit NMAG]: %RED%# %WHITE%Monarch %RED%[%WHITE%%SOCKETS%%RED%] %RED%#
ItemDisplay[SUP uit NMAG]: %RED%# %WHITE%Superior Monarch %RED%[%WHITE%%SOCKETS%%RED%] %RED%#

